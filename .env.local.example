# Copy this file to .env.local and fill in your values

# Anthropic API Key (get from https://console.anthropic.com/)
ANTHROPIC_API_KEY=sk-ant-xxxxx

# FrontSteps Credentials
FRONTSTEPS_EMAIL=your-email@example.com
